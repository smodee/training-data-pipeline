# Authentication is handled by suuntool itself — run `suuntool login` once.
# Everything below is optional; defaults are shown. Adjust HR zones to your physiology.

# Path to the suuntool executable (omit if it's already on your PATH).
# SUUNTOOL_PATH=suuntool

# Rolling daily-TSS history used to seed CTL/ATL (created automatically).
# TSS_HISTORY_FILE=~/.training_log_tss.json

# Heart-rate thresholds for zone boundaries and hrTSS fallback.
# VT1_BPM=145
# VT2_BPM=171
# MAX_HR=191
# Threshold (lactate/functional) HR for hrTSS; defaults to VT2 if unset.
# THRESHOLD_HR=171

# OUTPUT_DIR=./training_logs
